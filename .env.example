# Bu dosyayı .env olarak kopyalayıp gerçek değerlerinizi girin.
# .env dosyasını ASLA git'e commit etmeyin (.dockerignore ve .gitignore'da hariç tutulmalı).

# ---- Genel ----
SECRET_KEY=buraya-uzun-rastgele-bir-anahtar-yazin
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

# ---- Portal şifreleme (Genel Ayarlar > Portal) ----
# Üretmek için: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PORTAL_ENCRYPTION_KEY=

# ---- E-posta (E-Arşiv bildirimleri) ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@zenithar.com

# ---- SMS (E-Arşiv bildirimleri, opsiyonel) ----
SMS_API_URL=
SMS_API_KEY=

# ---- GİB / E-Fatura entegratörü (opsiyonel; asıl kaynak Genel Ayarlar > Portal) ----
GIB_INTEGRATION_PROVIDER=
GIB_API_URL=
GIB_API_KEY=

# ---- Cache (Aşama 42) ----
# "redis" yaparsanız REDIS_URL da girin; boş bırakırsanız LocMemCache kullanılır.
CACHE_BACKEND=
REDIS_URL=redis://redis:6379/1
